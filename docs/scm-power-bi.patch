--- a/deploy/server.js
+++ b/deploy/server.js
@@ -5,9 +5,11 @@ const http = require("http");
 const fs = require("fs");
 const path = require("path");
 
+// API_BASE selects the environment: demo cockpit -> demo SCM Master, prod -> prod.
+// The cockpit only reads, so default to the read-only guest (never admin).
 const API   = process.env.API_BASE || "https://scm-master-production.up.railway.app";
-const USER  = process.env.API_USER || "admin@example.com";
-const PASS  = process.env.API_PASS || "admin";
+const USER  = process.env.API_USER || "guest@example.com";
+const PASS  = process.env.API_PASS || "guest";
 const PORT  = process.env.PORT || 8080;
 const REFRESH_MS = (process.env.REFRESH_SECONDS ? +process.env.REFRESH_SECONDS : 300) * 1000;
 
